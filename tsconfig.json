{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "outDir": "./renderer/js",
    "rootDir": "./renderer/src",
    "sourceMap": true,
    "declaration": true,
    "declarationDir": "./renderer/types",
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false
  },
  "include": ["renderer/src/**/*", "renderer/js/**/*.js"],
  "exclude": ["node_modules", "release", "renderer/vendor"]
}
